# Included by CMakeLists, edited by the build script
# (the version numbers are generated by the build script from the git current label)

set(SLIC3R_APP_NAME "SanityPrint")
set(SLIC3R_APP_KEY "Creality")
set(SLIC3R_APP_USE_FORDER "Sanity Print")
if(NOT DEFINED PROCESS_NAME)
set(PROCESS_NAME "SanityPrint")
endif()
set(VENDOR_NAME "Creality")
set(STARTUP_PROJECT_NAME "${PROCESS_NAME}_app_gui")
set(SOLUTION_NAME "${PROCESS_NAME}")



if(NOT DEFINED UPDATE_ONLINE_MACHINES)
    set(UPDATE_ONLINE_MACHINES "1")
endif()

if(NOT DEFINED BBL_RELEASE_TO_PUBLIC)
set(BBL_RELEASE_TO_PUBLIC "1")
endif()
if(NOT DEFINED BBL_INTERNAL_TESTING)
set(BBL_INTERNAL_TESTING "0")
endif()
if(NOT DEFINED SANITYPRINT_VERSION)
# This file is a placeholder that Creality's release build script rewrites with the
# version generated from the git label (see the header comment above). Replicate that
# here so a build checked out at a release tag (e.g. v7.1.1) reports the correct version
# instead of the 7.0.0 placeholder. Overridable with -DSANITYPRINT_VERSION=... and
# skipped automatically when not building from a git working tree.
set(SANITYPRINT_VERSION "7.0.0")
find_package(Git QUIET)
if(GIT_FOUND AND EXISTS "${CMAKE_SOURCE_DIR}/.git")
    execute_process(
        COMMAND ${GIT_EXECUTABLE} describe --tags --abbrev=0
        WORKING_DIRECTORY ${CMAKE_SOURCE_DIR}
        OUTPUT_VARIABLE _cp_git_tag
        OUTPUT_STRIP_TRAILING_WHITESPACE
        ERROR_QUIET)
    if(_cp_git_tag MATCHES "^[vV]?([0-9]+\\.[0-9]+\\.[0-9]+)")
        set(SANITYPRINT_VERSION "${CMAKE_MATCH_1}")
        # The internal build number (e.g. 4472 in the official V7.1.1.4472) is a CI counter
        # that is NOT present in the public squashed source mirror (this repo has only ~46
        # commits). Supply it via the BUILD_ID env var to reproduce an official build's
        # full 4-part version string; without it the build is just the X.Y.Z from the tag.
        if(DEFINED ENV{BUILD_ID} AND NOT "$ENV{BUILD_ID}" STREQUAL "")
            set(SANITYPRINT_VERSION "${SANITYPRINT_VERSION}.$ENV{BUILD_ID}")
        endif()
    endif()
endif()
message(STATUS "SANITYPRINT_VERSION resolved to ${SANITYPRINT_VERSION}")
endif()

string(REGEX MATCH "^[0-9]+\\.[0-9]+\\.[0-9]+\\.([0-9]+)" SANITYPRINT_VERSION_WITH_BUILD "${SANITYPRINT_VERSION}")
if(CMAKE_MATCH_1)
set(SLIC3R_BUILD_ID "${CMAKE_MATCH_1}")
elseif(NOT DEFINED SLIC3R_BUILD_ID OR "${SLIC3R_BUILD_ID}" STREQUAL "")
set(SLIC3R_BUILD_ID "$ENV{BUILD_ID}")
endif()

if(NOT DEFINED PROJECT_VERSION_EXTRA)
set(PROJECT_VERSION_EXTRA "Alpha")
endif()

string(REGEX MATCH "^([0-9]+)\\.([0-9]+)\\.([0-9]+)" CXSW3D ${SANITYPRINT_VERSION})
set(SANITYPRINT_VERSION_MAJOR ${CMAKE_MATCH_1})
set(SANITYPRINT_VERSION_MINOR ${CMAKE_MATCH_2})
set(SANITYPRINT_VERSION_PATCH ${CMAKE_MATCH_3})
set(SLIC3R_VERSION "01.09.03.50")
